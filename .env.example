# Core
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# Admin security (required in production)
ADMIN_PASSWORD=change_this_to_a_long_random_password
ADMIN_TOKEN_SECRET=change_this_to_a_long_random_secret
ADMIN_TOKEN_TTL_MS=43200000

# Production safety switches
# Keep false unless you explicitly want destructive sync behavior in production.
ALLOW_DESTRUCTIVE_SYNC=false
# Keep false to avoid auto-seeding (which can clear data paths) on production boot.
ENABLE_SEED_ON_BOOT=false

# Optional integrations
DATA_PROVIDER_PRIMARY=pandascore
PANDASCORE_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=rivox
